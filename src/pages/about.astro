---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="About | My Academic Tutor"
  description="Learn about My Academic Tutor, an academic tutoring team founded by Rahul, Indian Institute of Technology Kanpur alumnus, with expertise in statistics, medical statistics and health data science."
>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            About
          </p>

          <h1 class="mt-4 text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
            Academic tutoring built around subject-focused support.
          </h1>
        </div>

        <div>
          <p class="text-lg leading-8 text-neutral-700">
            My Academic Tutor is an academic tutoring team supporting
            students and researchers across quantitative, computational and
            research-focused subjects.
          </p>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            Founded by Rahul, Indian Institute of Technology Kanpur alumnus, with
            expertise in statistics, medical statistics and health data science.
            The platform brings together tutors for different subject areas while
            keeping support structured, personal and academically focused.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-3">
        <div class="border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Since 2020
          </p>

          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-950">
            Global academic support
          </h2>

          <p class="mt-3 text-sm leading-6 text-neutral-600">
            We have supported students across countries, degree levels and
            academic backgrounds.
          </p>
        </div>

        <div class="border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Tutor team
          </p>

          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-950">
            Subject-focused tutors
          </h2>

          <p class="mt-3 text-sm leading-6 text-neutral-600">
            Different tutors support different academic areas, from statistics
            and programming to bioinformatics and research methods.
          </p>
        </div>

        <div class="border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Founded by Rahul
          </p>

          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-950">
            IIT Kanpur alumnus
          </h2>

          <p class="mt-3 text-sm leading-6 text-neutral-600">
            Expertise in statistics, medical statistics and health data science.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-[#f8f6f2] px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            How we work
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
            Clear, structured and academically responsible.
          </h2>
        </div>

        <div class="border-y border-neutral-300">
          <div class="grid gap-4 border-b border-neutral-200 py-6 md:grid-cols-[0.7fr_1.3fr]">
            <h3 class="text-xl font-semibold text-neutral-950">
              Understand the requirement
            </h3>

            <p class="text-sm leading-6 text-neutral-700">
              We first review the subject, level, software requirements,
              deadline and type of support needed.
            </p>
          </div>

          <div class="grid gap-4 border-b border-neutral-200 py-6 md:grid-cols-[0.7fr_1.3fr]">
            <h3 class="text-xl font-semibold text-neutral-950">
              Match the support
            </h3>

            <p class="text-sm leading-6 text-neutral-700">
              We suggest a suitable tutor or support route based on the academic
              area and technical requirements.
            </p>
          </div>

          <div class="grid gap-4 py-6 md:grid-cols-[0.7fr_1.3fr]">
            <h3 class="text-xl font-semibold text-neutral-950">
              Focus on understanding
            </h3>

            <p class="text-sm leading-6 text-neutral-700">
              The aim is to help students understand concepts, methods, software
              workflows and interpretation rather than simply memorising answers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <ContactCTA />
  </main>

  <Footer />
</BaseLayout>