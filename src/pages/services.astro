---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";

const services = [
  {
    title: "Statistics",
    description:
      "Core statistical support for undergraduate, postgraduate and research-level study.",
    topics: [
      "Probability theory",
      "Statistical inference",
      "Hypothesis testing",
      "Regression analysis",
      "Generalised linear models",
      "Multivariate analysis",
      "Time series analysis",
      "Bayesian statistics",
    ],
  },
  {
    title: "Biostatistics & Medical Statistics",
    description:
      "Support for clinical, epidemiological and biomedical data-analysis topics.",
    topics: [
      "Survival analysis",
      "Clinical trials",
      "Epidemiology",
      "Sample size calculation",
      "Diagnostic test evaluation",
      "Logistic regression",
      "Longitudinal data analysis",
      "Meta-analysis",
    ],
  },
  {
    title: "Programming & Statistical Software",
    description:
      "Practical support with statistical software and coding workflows used in academic research and applied analysis.",
    topics: [
      "R programming",
      "Python for data analysis",
      "SPSS",
      "SAS",
      "Stata",
      "R Markdown / Quarto",
      "Data cleaning",
      "Reproducible reports",
    ],
  },
  {
    title: "Data Science & Machine Learning",
    description:
      "Applied support from data preparation to modelling, validation and communication.",
    topics: [
      "Exploratory data analysis",
      "Data visualisation",
      "Machine learning",
      "Classification models",
      "Prediction modelling",
      "Feature engineering",
      "Model evaluation",
      "Interpretability",
    ],
  },
  {
    title: "Bioinformatics & Omics",
    description:
      "Support for biological data analysis and computational biology workflows.",
    topics: [
      "RNA-seq concepts",
      "Gene expression analysis",
      "Differential expression",
      "Bioconductor workflows",
      "Single-cell concepts",
      "Omics data analysis",
      "Pathway analysis",
      "Biological interpretation",
    ],
  },
  {
    title: "Quantitative Research Support",
    description:
      "Guidance for dissertations, theses, reports and academic data-analysis projects.",
    topics: [
      "Research design",
      "Dissertation analysis",
      "Survey analysis",
      "Questionnaire data",
      "Methodology writing",
      "Results interpretation",
      "Tables and figures",
      "Academic reporting",
    ],
  },
];
---

<BaseLayout
  title="Services | My Academic Tutor"
  description="Academic tutoring and research support across statistics, biostatistics, programming, data science, bioinformatics and quantitative research methods."
>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Services
        </p>

        <h1 class="mt-4 max-w-5xl text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
          Academic support across subjects, software and research projects.
        </h1>

        <p class="mt-7 max-w-3xl text-lg leading-8 text-neutral-700">
          Support is organised around clear explanation, software practice,
          analytical planning, interpretation and academic communication.
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-2">
        {services.map((service) => (
          <article class="border border-neutral-200 bg-white p-7 shadow-sm">
            <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">
              {service.title}
            </h2>

            <p class="mt-4 text-sm leading-6 text-neutral-600">
              {service.description}
            </p>

            <div class="mt-6 grid gap-2 sm:grid-cols-2">
              {service.topics.map((topic) => (
                <div class="border border-neutral-200 bg-[#f8f6f2] px-4 py-3">
                  <span class="text-sm text-neutral-700">{topic}</span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <ContactCTA />
  </main>

  <Footer />
</BaseLayout>