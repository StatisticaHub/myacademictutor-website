---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const resources = [
  {
    title: "How to choose the correct statistical test",
    description:
      "A practical guide for students deciding between t-tests, ANOVA, chi-square tests, correlation, regression and non-parametric methods.",
    tag: "Statistics",
    level: "Foundation",
    href: "resources/choosing-statistical-test",
    status: "Read guide",
    keywords:
      "statistical test t-test anova chi-square correlation regression non-parametric hypothesis testing",
  },
  {
    title: "How to prepare your data before analysis",
    description:
      "A student-friendly checklist covering missing values, variable coding, outliers, data types and basic exploratory analysis.",
    tag: "Data analysis",
    level: "Foundation",
    href: "resources/prepare-data-before-analysis",
    status: "Read guide",
    keywords:
      "data cleaning missing values outliers coding variables data preparation exploratory analysis",
  },
  {
    title: "Common mistakes in dissertation data analysis",
    description:
      "A guide to avoiding unclear research questions, unsuitable methods, weak interpretation and poor reporting of results.",
    tag: "Research support",
    level: "Foundation",
    href: "resources/dissertation-data-analysis-mistakes",
    status: "Read guide",
    keywords:
      "dissertation analysis research project mistakes methodology results interpretation reporting",
  },
  {
    title: "R, Python, SPSS, SAS or Stata: which should I use?",
    description:
      "A practical comparison for students choosing software for coursework, dissertation analysis or research projects.",
    tag: "Software",
    level: "Foundation",
    href: "resources/statistical-software-guide",
    status: "Read guide",
    keywords:
      "R Python SPSS SAS Stata software statistical software data analysis programming",
  },
  {
    title: "Understanding p-values, confidence intervals and effect sizes",
    description:
      "A clearer explanation of statistical significance, practical importance and how to report results responsibly.",
    tag: "Statistics",
    level: "Intermediate",
    href: "resources/p-values-confidence-intervals-effect-sizes",
    status: "Read guide",
    keywords:
      "p value confidence interval effect size statistical significance practical significance interpretation",
  },
  {
    title: "Linear regression assumptions and diagnostics",
    description:
      "A guide to checking linearity, residuals, heteroscedasticity, influential points and model fit.",
    tag: "Regression",
    level: "Intermediate",
    href: "resources/linear-regression-assumptions-diagnostics",
    status: "Read guide",
    keywords:
      "linear regression assumptions diagnostics residuals heteroscedasticity multicollinearity influence model fit",
  },
  {
    title: "Logistic regression explained for health and social science students",
    description:
      "A practical introduction to odds ratios, binary outcomes, model interpretation and reporting logistic regression.",
    tag: "Regression",
    level: "Intermediate",
    href: "resources/logistic-regression-health-social-science",
    status: "Read guide",
    keywords:
      "logistic regression odds ratio binary outcome health data epidemiology interpretation",
  },
  {
    title: "Survival analysis: Kaplan–Meier curves and Cox regression",
    description:
      "An introduction to time-to-event data, censoring, Kaplan–Meier curves, log-rank tests and Cox models.",
    tag: "Biostatistics",
    level: "Advanced",
    href: "resources/survival-analysis-kaplan-meier-cox-regression",
    status: "Read guide",
    keywords:
      "survival analysis Kaplan Meier Cox regression censoring hazard ratio log rank time to event",
  },
  {
    title: "Choosing between correlation and regression",
    description:
      "A guide to when correlation is enough, when regression is better, and how to avoid overinterpreting association.",
    tag: "Statistics",
    level: "Intermediate",
    href: "resources/choosing-between-correlation-and-regression",
    status: "Read guide",
    keywords:
      "correlation regression association prediction relationship Pearson Spearman causation",
  },
  {
    title: "ANOVA, ANCOVA and repeated measures ANOVA",
    description:
      "A practical guide to comparing groups, adjusting for covariates and handling repeated measurements.",
    tag: "Statistics",
    level: "Advanced",
    href: "resources/anova-ancova-repeated-measures-anova",
    status: "Read guide",
    keywords:
      "ANOVA ANCOVA repeated measures group comparison covariates within subject between subject",
  },
  {
    title: "Non-parametric tests: when and how to use them",
    description:
      "A guide to Mann–Whitney, Wilcoxon, Kruskal–Wallis and Spearman tests for non-normal or ordinal data.",
    tag: "Statistics",
    level: "Intermediate",
    href: "resources/non-parametric-tests-when-and-how",
    status: "Read guide",
    keywords:
      "non parametric Mann Whitney Wilcoxon Kruskal Wallis Spearman ordinal data non normal",
  },
  {
    title: "Missing data: deletion, imputation and reporting",
    description:
      "A student-friendly guide to understanding missingness, complete case analysis and basic imputation choices.",
    tag: "Data analysis",
    level: "Advanced",
    href: "resources/missing-data-deletion-imputation-reporting",
    status: "Read guide",
    keywords:
      "missing data imputation complete case deletion MCAR MAR MNAR reporting data analysis",
  },
  {
    title: "Sample size, power and precision explained",
    description:
      "A guide to understanding sample size calculations, statistical power, detectable effects and confidence interval precision.",
    tag: "Research methods",
    level: "Intermediate",
    href: "resources/sample-size-power-precision-explained",
    status: "Read guide",
    keywords:
      "sample size power calculation precision effect size study design hypothesis test",
  },
  {
    title: "How to write a statistical analysis plan",
    description:
      "A practical guide to planning outcomes, variables, methods, subgroup analyses and reporting before analysis begins.",
    tag: "Research support",
    level: "Advanced",
    href: "resources/statistical-analysis-plan-guide",
    status: "Read guide",
    keywords:
      "statistical analysis plan SAP methods outcomes variables subgroup analysis reporting",
  },
  {
    title: "How to report regression results in a dissertation",
    description:
      "A guide to writing regression methods, tables, coefficients, confidence intervals and interpretation clearly.",
    tag: "Research support",
    level: "Intermediate",
    href: "resources/report-regression-results-dissertation",
    status: "Read guide",
    keywords:
      "report regression results dissertation coefficients confidence interval interpretation table",
  },
  {
    title: "Confounding, mediation and effect modification",
    description:
      "A conceptual guide to three common ideas students meet in epidemiology, medical statistics and social research.",
    tag: "Epidemiology",
    level: "Advanced",
    href: "resources/confounding-mediation-effect-modification",
    status: "Read guide",
    keywords:
      "confounding mediation effect modification interaction epidemiology causal inference",
  },
  {
    title: "Introduction to causal inference and DAGs",
    description:
      "A beginner-to-intermediate guide to causal questions, confounder selection, directed acyclic graphs and adjustment.",
    tag: "Causal inference",
    level: "Advanced",
    href: "resources/causal-inference-dags-introduction",
    status: "Read guide",
    keywords:
      "causal inference DAG directed acyclic graph confounding adjustment causal effect",
  },
  {
    title: "Model validation: overfitting, train-test split and cross-validation",
    description:
      "A practical guide to evaluating prediction models and avoiding overly optimistic performance estimates.",
    tag: "Data science",
    level: "Advanced",
    href: "resources/model-validation-overfitting-cross-validation",
    status: "Read guide",
    keywords:
      "model validation overfitting train test split cross validation prediction performance",
  },
  {
    title: "ROC curves, sensitivity, specificity and AUC",
    description:
      "A guide to diagnostic test evaluation and classification model performance in health and data science.",
    tag: "Biostatistics",
    level: "Intermediate",
    href: "resources/roc-sensitivity-specificity-auc",
