  },
  {
    title: "Multiple testing and false discovery rate",
    description:
      "A guide to p-value adjustment, Bonferroni correction and false discovery rate in high-dimensional analysis.",
    tag: "Statistics",
    level: "Advanced",
    href: "resources/multiple-testing-false-discovery-rate",
    status: "Read guide",
    keywords:
      "multiple testing false discovery rate FDR Bonferroni p value adjustment high dimensional",
  },
  {
    title: "Introduction to meta-analysis",
    description:
      "A guide to effect sizes, forest plots, heterogeneity, fixed-effect models and random-effects models.",
    tag: "Evidence synthesis",
    level: "Advanced",
    href: "resources/introduction-to-meta-analysis",
    status: "Read guide",
    keywords:
      "meta analysis forest plot heterogeneity fixed effect random effects systematic review",
  },
  {
    title: "Longitudinal data analysis: repeated measurements over time",
    description:
      "A guide to analysing outcomes measured repeatedly using repeated measures, mixed models and growth patterns.",
    tag: "Statistics",
    level: "Advanced",
    href: "resources/longitudinal-data-repeated-measurements",
    status: "Read guide",
    keywords:
      "longitudinal data repeated measures mixed models time outcome growth curve",
  },
  {
    title: "Introduction to mixed-effects models",
    description:
      "A practical explanation of fixed effects, random effects, clustering and hierarchical data structures.",
    tag: "Regression",
    level: "Advanced",
    href: "resources/mixed-effects-models-introduction",
    status: "Read guide",
    keywords:
      "mixed effects model fixed effects random effects multilevel hierarchical clustered data",
  },
  {
    title: "RNA-seq and differential expression analysis: basic concepts",
    description:
      "A student-friendly introduction to counts, normalisation, differential expression and biological interpretation.",
    tag: "Bioinformatics",
    level: "Advanced",
    href: "resources/rna-seq-differential-expression-basic-concepts",
    status: "Read guide",
    keywords:
      "RNA-seq differential expression counts normalization DESeq2 edgeR bioinformatics",
  },
  {
    title: "Reproducible analysis with R Markdown or Quarto",
    description:
      "A guide to combining code, outputs, interpretation and reporting in one reproducible academic workflow.",
    tag: "Software",
    level: "Intermediate",
    href: "resources/reproducible-analysis-r-markdown-quarto",
    status: "Read guide",
    keywords:
      "R Markdown Quarto reproducible analysis report code output academic writing",
  },
];

const tags = [...new Set(resources.map((item) => item.tag))];
---

<BaseLayout
  title="Resources | My Academic Tutor"
  description="Student resources on statistics, biostatistics, data analysis, software and dissertation research support."
>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Resources
        </p>

        <h1 class="mt-4 max-w-5xl text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
          Practical guides for students and researchers.
        </h1>

        <p class="mt-7 max-w-3xl text-lg leading-8 text-neutral-700">
          Short, student-friendly resources to help with statistics,
          biostatistics, software, data analysis and research projects.
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-12 md:px-10 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-4 lg:grid-cols-[1fr_0.35fr]">
          <label class="grid gap-2">
            <span class="text-sm font-medium text-neutral-950">
              Search resources
            </span>

            <input
              id="resource-search"
              type="search"
              placeholder="Search: regression, p-value, survival analysis, SPSS, missing data, dissertation..."
              class="border border-neutral-300 bg-white px-4 py-3 text-neutral-950 outline-none transition placeholder:text-neutral-400 focus:border-[#8C1515]"
            />
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-medium text-neutral-950">
              Filter by area
            </span>

            <select
              id="resource-filter"
              class="border border-neutral-300 bg-white px-4 py-3 text-neutral-950 outline-none transition focus:border-[#8C1515]"
            >
              <option value="all">All areas</option>
              {tags.map((tag) => (
                <option value={tag}>{tag}</option>
              ))}
            </select>
          </label>
        </div>

        <div class="mt-5 flex flex-wrap gap-2 text-sm text-neutral-500">
          <span>Popular searches:</span>
          <span class="text-neutral-700">regression</span>
          <span>·</span>
          <span class="text-neutral-700">survival analysis</span>
          <span>·</span>
          <span class="text-neutral-700">missing data</span>
          <span>·</span>
          <span class="text-neutral-700">p-value</span>
          <span>·</span>
          <span class="text-neutral-700">dissertation analysis</span>
          <span>·</span>
          <span class="text-neutral-700">SPSS</span>
        </div>
      </div>
    </section>

    <section class="bg-white px-6 pb-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Learning support
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950">
            Start with a practical guide.
          </h2>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            These resources are designed to help students ask better questions,
            understand common decisions and prepare for tutoring or research
            support.
          </p>

          <a
            href={`${base}contact`}
            class="mt-8 inline-flex rounded-sm bg-[#8C1515] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#6f1111]"
          >
            Submit requirement
          </a>
        </div>

        <div>
          <p id="resource-count" class="mb-5 text-sm text-neutral-500">
            Showing {resources.length} resources
          </p>

          <div id="resource-grid" class="grid gap-5">
            {resources.map((item) => (
              <article
                class="resource-card border border-neutral-200 bg-[#f8f6f2] p-6 shadow-sm transition hover:border-[#8C1515]"
                data-title={item.title.toLowerCase()}
                data-description={item.description.toLowerCase()}
                data-tag={item.tag.toLowerCase()}
                data-level={item.level.toLowerCase()}
                data-keywords={item.keywords.toLowerCase()}
              >
                <div class="flex flex-wrap items-center gap-3">
                  <p class="text-sm font-medium text-[#8C1515]">
                    {item.tag}
                  </p>

                  <span class="text-sm text-neutral-400">/</span>

                  <p class="text-sm text-neutral-500">
                    {item.level}
                  </p>
                </div>

                <h3 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-950">
                  {item.title}
                </h3>

                <p class="mt-3 text-sm leading-6 text-neutral-600">
                  {item.description}
                </p>

                <a
                  href={`${base}${item.href}`}
                  class="mt-5 inline-flex text-sm font-medium text-neutral-950 transition hover:text-[#8C1515]"
                >
                  Read guide →
                </a>
              </article>
            ))}
          </div>

          <p
            id="no-results"
            class="mt-8 hidden border border-neutral-200 bg-[#f8f6f2] p-6 text-sm leading-6 text-neutral-700"
          >
            No matching resources found. Try searching for a broader term such
            as regression, data analysis, dissertation, software or statistics.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const searchInput = document.querySelector("#resource-search");
  const filterSelect = document.querySelector("#resource-filter");
  const cards = Array.from(document.querySelectorAll(".resource-card"));
  const count = document.querySelector("#resource-count");
  const noResults = document.querySelector("#no-results");

  const updateResources = () => {
    const query = searchInput?.value.toLowerCase().trim() || "";
    const selectedTag = filterSelect?.value.toLowerCase() || "all";

    let visibleCount = 0;

    cards.forEach((card) => {
      const text = [
        card.dataset.title,
        card.dataset.description,
        card.dataset.tag,
        card.dataset.level,
        card.dataset.keywords,
      ].join(" ");

      const matchesSearch = !query || text.includes(query);
      const matchesTag = selectedTag === "all" || card.dataset.tag === selectedTag;
      const shouldShow = matchesSearch && matchesTag;

      card.classList.toggle("hidden", !shouldShow);

      if (shouldShow) {
        visibleCount += 1;
      }
    });

    if (count) {
      count.textContent = `Showing ${visibleCount} resource${visibleCount === 1 ? "" : "s"}`;
    }

    noResults?.classList.toggle("hidden", visibleCount !== 0);
  };

  searchInput?.addEventListener("input", updateResources);
  filterSelect?.addEventListener("change", updateResources);
</script>