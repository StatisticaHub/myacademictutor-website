export function getStaticPaths() {
  return Object.entries(guidePages).map(([slug, guide]) => ({
    params: { slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
---

<BaseLayout title={`${guide.title} | My Academic Tutor`} description={guide.description}>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto max-w-5xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          {guide.tag} guide / {guide.level}
        </p>

        <h1 class="mt-4 text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
          {guide.title}
        </h1>

        <p class="mt-7 text-lg leading-8 text-neutral-700">
          {guide.intro}
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.75fr_1.25fr]">
        <aside>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Key terms
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950">
            Start with the core ideas.
          </h2>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            Understanding the language of the method makes it easier to choose,
            apply and report the analysis correctly.
          </p>

          <a
            href={`${base}contact`}
            class="mt-8 inline-flex rounded-sm bg-[#8C1515] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#6f1111]"
          >
            Ask for support
          </a>
        </aside>

        <div class="grid gap-5">
          {guide.keyTerms.map((item) => (
            <article class="border border-neutral-200 bg-[#f8f6f2] p-6">
              <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">
                {item.term}
              </h2>

              <p class="mt-3 text-sm leading-6 text-neutral-700">
                {item.meaning}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#f8f6f2] px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Guide
        </p>

        <h2 class="mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-neutral-950">
          What students should understand.
        </h2>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {guide.sections.map((section) => (
            <article class="border border-neutral-200 bg-white p-6 shadow-sm">
              <h3 class="text-2xl font-semibold tracking-tight text-neutral-950">
                {section.heading}
              </h3>

              <p class="mt-3 text-sm leading-6 text-neutral-700">
                {section.body}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Checklist
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950">
            Before writing your results.
          </h2>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            Use this checklist to make your analysis and reporting clearer,
            more transparent and easier to defend.
          </p>
        </div>

        <div class="grid gap-3">
          {guide.checklist.map((item) => (
            <div class="border border-neutral-200 bg-[#f8f6f2] px-5 py-4">
              <p class="text-sm leading-6 text-neutral-700">
                {item}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#f8f6f2] px-6 py-16 md:px-10 lg:px-20">
      <div class="mx-auto max-w-4xl border-t border-neutral-300 pt-10">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Need help?
        </p>

        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl">
          Apply this guide to your own coursework, dissertation or project.
        </h2>

        <p class="mt-4 text-lg leading-8 text-neutral-700">
          Share your subject, data, software requirement and deadline. We can
          help you understand the method, plan the analysis and interpret your
          results.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href={`${base}contact`}
            class="rounded-sm bg-[#8C1515] px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-[#6f1111]"
          >
            Submit requirement
          </a>

          <a
            href={`${base}resources`}
            class="rounded-sm border border-neutral-300 bg-white px-6 py-3 text-center text-sm font-medium text-neutral-950 transition hover:border-[#8C1515] hover:text-[#8C1515]"
          >
            View all resources
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>