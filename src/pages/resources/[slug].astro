---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const guidePages = {
  "p-values-confidence-intervals-effect-sizes": {
    title: "Understanding p-values, confidence intervals and effect sizes",
    tag: "Statistics",
    level: "Intermediate",
    description:
      "A clearer explanation of statistical significance, practical importance and how to report results responsibly.",
    intro:
      "Students often report results as simply significant or not significant. A stronger interpretation explains the p-value, the effect estimate, the confidence interval and whether the result matters in context.",
    keyTerms: [
      {
        term: "p-value",
        meaning:
          "Helps assess how incompatible the observed data are with a null model or hypothesis.",
      },
      {
        term: "Confidence interval",
        meaning:
          "Shows a range of plausible values for the effect estimate and gives a sense of precision.",
      },
      {
        term: "Effect size",
        meaning:
          "Describes how large or meaningful a difference, association or effect is.",
      },
    ],
    sections: [
      {
        heading: "Do not stop at the p-value",
        body:
          "A small p-value may suggest evidence against a null hypothesis, but it does not show whether the effect is large, important or useful. A large p-value also does not prove that there is no effect.",
      },
      {
        heading: "Use confidence intervals to discuss uncertainty",
        body:
          "A confidence interval helps you discuss precision. A narrow interval suggests a more precise estimate, while a wide interval suggests more uncertainty.",
      },
      {
        heading: "Effect size answers a different question",
        body:
          "Effect size helps answer whether the result is meaningful. Depending on the analysis, this could be a mean difference, odds ratio, risk ratio, hazard ratio, correlation or standardised effect.",
      },
      {
        heading: "Better reporting",
        body:
          "A strong result sentence includes the estimate, confidence interval, p-value and plain-language interpretation. Avoid reporting only whether p < 0.05.",
      },
    ],
    checklist: [
      "Report the estimate, not only the p-value.",
      "Include a confidence interval where appropriate.",
      "Explain the direction and size of the effect.",
      "Discuss practical, clinical or academic importance.",
      "Avoid saying p > 0.05 proves no effect.",
      "Avoid saying p < 0.05 proves importance.",
    ],
  },

  "linear-regression-assumptions-diagnostics": {
    title: "Linear regression assumptions and diagnostics",
    tag: "Regression",
    level: "Intermediate",
    description:
      "A guide to checking linearity, residuals, heteroscedasticity, influential points and model fit.",
    intro:
      "Linear regression is widely used, but the model should be checked before interpreting coefficients. Diagnostics help you see whether the model is a reasonable summary of the data.",
    keyTerms: [
      {
        term: "Linearity",
        meaning:
          "The relationship between predictors and the outcome should be approximately linear.",
      },
      {
        term: "Residuals",
        meaning:
          "Differences between observed and fitted values; useful for checking model problems.",
      },
      {
        term: "Influential observations",
        meaning:
          "Observations that strongly affect coefficient estimates or model fit.",
      },
    ],
    sections: [
      {
        heading: "Check the form of the relationship",
        body:
          "Scatterplots and residual plots help assess whether a linear model is appropriate. Curved residual patterns may suggest non-linearity.",
      },
      {
        heading: "Check residual behaviour",
        body:
          "Residuals should not show strong patterns. Unequal spread may indicate heteroscedasticity, and unusual residuals may indicate outliers.",
      },
      {
        heading: "Check multicollinearity",
        body:
          "Highly correlated predictors can make coefficients unstable and difficult to interpret. Variance inflation factors are commonly used to screen for this issue.",
      },
      {
        heading: "Check influence",
        body:
          "Some observations may have a large effect on the model. Cook’s distance, leverage and residual diagnostics can help identify them.",
      },
    ],
    checklist: [
      "Plot outcome against key continuous predictors.",
      "Inspect residual plots.",
      "Check for non-constant variance.",
      "Check influential observations.",
      "Check multicollinearity among predictors.",
      "Report what diagnostic checks were performed.",
    ],
  },

  "logistic-regression-health-social-science": {
    title: "Logistic regression explained for health and social science students",
    tag: "Regression",
    level: "Intermediate",
    description:
      "A practical introduction to odds ratios, binary outcomes, model interpretation and reporting logistic regression.",
    intro:
      "Logistic regression is used when the outcome is binary, such as disease/no disease, pass/fail or yes/no. It estimates how predictors relate to the odds of the outcome.",
    keyTerms: [
      {
        term: "Binary outcome",
        meaning:
          "An outcome with two categories, such as event/no event or yes/no.",
      },
      {
        term: "Odds ratio",
        meaning:
          "A measure comparing the odds of an outcome between groups or across predictor values.",
      },
      {
        term: "Adjusted model",
        meaning:
          "A model including additional variables to account for potential confounding or other predictors.",
      },
    ],
    sections: [
      {
        heading: "Use logistic regression for binary outcomes",
        body:
          "If the outcome is coded as 0/1, logistic regression is often more appropriate than linear regression because predicted probabilities must stay between 0 and 1.",
      },
      {
        heading: "Interpret odds ratios carefully",
        body:
          "An odds ratio above 1 suggests higher odds of the outcome, while an odds ratio below 1 suggests lower odds. The reference category must always be clear.",
      },
      {
        heading: "Adjusted models need justification",
        body:
          "Variables should not be added randomly. Adjustment should be based on the research question, study design and potential confounding.",
      },
      {
        heading: "Report clearly",
        body:
          "Report odds ratios with confidence intervals and p-values where appropriate. Explain the result in plain language, not only with statistical terms.",
      },
    ],
    checklist: [
      "Confirm the outcome is binary.",
      "State the reference category.",
      "Report odds ratios with confidence intervals.",
      "Explain whether results are adjusted or unadjusted.",
      "Check sample size and sparse categories.",
      "Avoid interpreting odds ratios as risk ratios unless appropriate.",
    ],
  },

  "survival-analysis-kaplan-meier-cox-regression": {
    title: "Survival analysis: Kaplan–Meier curves and Cox regression",
    tag: "Biostatistics",
    level: "Advanced",
    description:
      "An introduction to time-to-event data, censoring, Kaplan–Meier curves, log-rank tests and Cox models.",
    intro:
      "Survival analysis is used when the outcome is time until an event, such as death, relapse, recovery or treatment failure. It is important because not everyone may experience the event during follow-up.",
    keyTerms: [
      {
        term: "Censoring",
        meaning:
          "Occurs when the exact event time is unknown because follow-up ended or the participant was lost before the event.",
      },
      {
        term: "Kaplan–Meier curve",
        meaning:
          "A curve showing estimated survival probability over time.",
      },
      {
        term: "Hazard ratio",
        meaning:
          "A measure comparing event rates between groups over time in a Cox model.",
      },
    ],
    sections: [
      {
        heading: "Time matters",
        body:
          "Survival analysis considers both whether the event occurred and when it occurred. This makes it different from ordinary binary outcome analysis.",
      },
      {
        heading: "Kaplan–Meier curves describe survival patterns",
        body:
          "Kaplan–Meier curves help compare event-free survival over time across groups. They are descriptive and often shown before modelling.",
      },
      {
        heading: "The log-rank test compares curves",
        body:
          "The log-rank test is commonly used to compare survival curves between groups, but it does not adjust for additional covariates.",
      },
      {
        heading: "Cox regression adjusts for predictors",
        body:
          "Cox proportional hazards regression estimates hazard ratios and can include multiple covariates. The proportional hazards assumption should be considered.",
      },
    ],
    checklist: [
      "Define the event clearly.",
      "Define time origin and follow-up time.",
      "Explain censoring.",
      "Use Kaplan–Meier curves for descriptive comparison.",
      "Use Cox regression when adjustment is needed.",
      "Check and report proportional hazards concerns.",
    ],
  },

  "choosing-between-correlation-and-regression": {
    title: "Choosing between correlation and regression",
    tag: "Statistics",
    level: "Intermediate",
    description:
      "A guide to when correlation is enough, when regression is better, and how to avoid overinterpreting association.",
    intro:
      "Correlation and regression both describe relationships, but they answer different questions. Correlation measures association; regression can model an outcome using one or more predictors.",
    keyTerms: [
      {
        term: "Correlation",
        meaning:
          "A measure of strength and direction of association between two variables.",
      },
      {
        term: "Regression",
        meaning:
          "A model for explaining or predicting an outcome from one or more predictors.",
      },
      {
        term: "Confounding",
        meaning:
          "A third variable that can distort the observed association between exposure and outcome.",
      },
    ],
    sections: [
      {
        heading: "Use correlation for simple association",
        body:
          "Correlation is useful when both variables are continuous and the aim is to describe association rather than prediction or adjustment.",
      },
      {
        heading: "Use regression for modelling an outcome",
        body:
          "Regression is better when one variable is clearly the outcome and you want to estimate the effect of predictors or adjust for other variables.",
      },
      {
        heading: "Correlation does not imply causation",
        body:
          "A correlation can arise from confounding, reverse causality, chance or genuine relationship. It does not prove one variable causes another.",
      },
      {
        heading: "Report context",
        body:
          "When reporting either correlation or regression, explain the variables, direction, size and limitations of the association.",
      },
    ],
    checklist: [
      "Identify whether you have an outcome variable.",
      "Use correlation only for simple association.",
      "Use regression for prediction or adjustment.",
      "Check scatterplots before analysis.",
      "Avoid causal wording unless design supports it.",
      "Report strength and direction clearly.",
    ],
  },

  "anova-ancova-repeated-measures-anova": {
    title: "ANOVA, ANCOVA and repeated measures ANOVA",
    tag: "Statistics",
    level: "Advanced",
    description:
      "A practical guide to comparing groups, adjusting for covariates and handling repeated measurements.",
    intro:
      "ANOVA-family methods are used for comparing means across groups, but the correct version depends on the design and whether covariates or repeated measurements are involved.",
    keyTerms: [
      {
        term: "ANOVA",
        meaning:
          "Compares mean outcomes across three or more groups.",
      },
      {
        term: "ANCOVA",
        meaning:
          "Compares group means while adjusting for continuous or categorical covariates.",
      },
      {
        term: "Repeated measures ANOVA",
        meaning:
          "Used when the same participants are measured repeatedly over time or conditions.",
      },
    ],
    sections: [
      {
        heading: "Use ANOVA for independent group comparisons",
        body:
          "One-way ANOVA is appropriate when comparing a continuous outcome across three or more independent groups.",
      },
      {
        heading: "Use ANCOVA when adjustment is needed",
        body:
          "ANCOVA can adjust for baseline or other covariates, but the covariates should be chosen based on study design and research question.",
      },
      {
        heading: "Use repeated measures ANOVA for within-subject designs",
        body:
          "When the same participants are measured multiple times, observations are not independent. Repeated measures methods account for this structure.",
      },
      {
        heading: "Post-hoc tests need care",
        body:
          "If the overall test suggests group differences, post-hoc comparisons may be used, but multiple comparison issues should be considered.",
      },
    ],
    checklist: [
      "Identify whether groups are independent or repeated.",
      "Check whether adjustment variables are needed.",
      "Check assumptions such as normality and equal variance.",
      "Use post-hoc comparisons carefully.",
      "Report group means and uncertainty.",
      "Explain the design clearly.",
    ],
  },

  "non-parametric-tests-when-and-how": {
    title: "Non-parametric tests: when and how to use them",
    tag: "Statistics",
    level: "Intermediate",
    description:
      "A guide to Mann–Whitney, Wilcoxon, Kruskal–Wallis and Spearman tests for non-normal or ordinal data.",
    intro:
      "Non-parametric tests are useful when standard parametric assumptions are not suitable, especially for ordinal data, skewed distributions or small samples.",
    keyTerms: [
      {
        term: "Mann–Whitney U test",
        meaning:
          "Compares two independent groups when a t-test may not be suitable.",
      },
      {
        term: "Wilcoxon signed-rank test",
        meaning:
          "Compares two paired or related measurements.",
      },
      {
        term: "Kruskal–Wallis test",
        meaning:
          "Compares three or more independent groups.",
      },
    ],
    sections: [
      {
        heading: "Non-parametric does not mean assumption-free",
        body:
          "These tests still have assumptions about design and measurement. They should not be used automatically whenever data look imperfect.",
      },
      {
        heading: "Choose based on study design",
        body:
          "Independent groups, paired observations and multiple groups require different tests.",
      },
      {
        heading: "Consider what is being compared",
        body:
          "Many non-parametric tests compare ranks rather than raw means. Interpret results accordingly.",
      },
      {
        heading: "Report clearly",
        body:
          "Report the test used, group summaries, p-value and a meaningful interpretation of the direction of difference.",
      },
    ],
    checklist: [
      "Identify independent vs paired design.",
      "Check number of groups.",
      "Consider whether outcome is ordinal or skewed.",
      "Use Spearman correlation for monotonic association.",
      "Report medians or suitable summaries.",
      "Avoid saying non-parametric tests have no assumptions.",
    ],
  },

  "missing-data-deletion-imputation-reporting": {
    title: "Missing data: deletion, imputation and reporting",
    tag: "Data analysis",
    level: "Advanced",
    description:
      "A student-friendly guide to understanding missingness, complete case analysis and basic imputation choices.",
    intro:
      "Missing data can affect bias, precision and interpretation. The first step is to understand how much data are missing and why they may be missing.",
    keyTerms: [
      {
        term: "Complete case analysis",
        meaning:
          "Analysis using only observations with complete data for all required variables.",
      },
      {
        term: "Imputation",
        meaning:
          "A method of replacing or estimating missing values using available information.",
      },
      {
        term: "Missingness mechanism",
        meaning:
          "The reason or pattern behind why values are missing.",
      },
    ],
    sections: [
      {
        heading: "Describe the missing data",
        body:
          "Report how much data are missing, which variables are affected and whether missingness differs between groups.",
      },
      {
        heading: "Deletion may be simple but risky",
        body:
          "Deleting incomplete records can reduce sample size and may bias results if data are not missing completely at random.",
      },
      {
        heading: "Imputation needs justification",
        body:
          "Imputation can be useful, but the method should match the data and analysis. Simple imputation can underestimate uncertainty.",
      },
      {
        heading: "Report decisions transparently",
        body:
          "Explain how missing data were handled and discuss the possible effect on results.",
      },
    ],
    checklist: [
      "Calculate missingness by variable.",
      "Check missingness by important groups.",
      "Avoid deleting cases without justification.",
      "Explain any imputation method.",
      "Report final analysis sample size.",
      "Discuss missing data as a limitation.",
    ],
  },

  "sample-size-power-precision-explained": {
    title: "Sample size, power and precision explained",
    tag: "Research methods",
    level: "Intermediate",
    description:
      "A guide to understanding sample size calculations, statistical power, detectable effects and confidence interval precision.",
    intro:
      "Sample size planning helps students understand whether a study is likely to estimate effects precisely or detect meaningful differences.",
    keyTerms: [
      {
        term: "Power",
        meaning:
          "The probability of detecting an effect of a specified size if that effect truly exists.",
      },
      {
        term: "Effect size",
        meaning:
          "The size of the difference or association the study aims to detect or estimate.",
      },
      {
        term: "Precision",
        meaning:
          "How narrow or wide an estimate’s confidence interval is expected to be.",
      },
    ],
    sections: [
      {
        heading: "Power depends on assumptions",
        body:
          "Power calculations require assumptions about effect size, variability, significance level and sample allocation.",
      },
      {
        heading: "Bigger samples are not automatically better",
        body:
          "A very large sample can detect tiny differences, but the result may not be practically important.",
      },
      {
        heading: "Precision is often more useful",
        body:
          "For estimation-focused studies, the width of the confidence interval may be more relevant than power.",
      },
      {
        heading: "Report assumptions",
        body:
          "A sample size calculation should state the expected effect size, variability, alpha level, power and any allowance for missing data.",
      },
    ],
    checklist: [
      "State the primary outcome.",
      "State the expected effect size.",
      "Use realistic assumptions.",
      "Allow for missing data or dropout.",
      "Explain whether the aim is testing or estimation.",
      "Report all calculation inputs.",
    ],
  },

  "statistical-analysis-plan-guide": {
    title: "How to write a statistical analysis plan",
    tag: "Research support",
    level: "Advanced",
    description:
      "A practical guide to planning outcomes, variables, methods, subgroup analyses and reporting before analysis begins.",
    intro:
      "A statistical analysis plan describes how data will be analysed before results are examined. It protects the analysis from unclear decisions and post-hoc changes.",
    keyTerms: [
      {
        term: "Primary outcome",
        meaning:
          "The main outcome the study is designed to analyse.",
      },
      {
        term: "Analysis population",
        meaning:
          "The set of participants or observations included in a specific analysis.",
      },
      {
        term: "Subgroup analysis",
        meaning:
          "Analysis examining whether results differ across predefined groups.",
      },
    ],
    sections: [
      {
        heading: "Start with the research question",
        body:
          "The analysis plan should follow the study aim and primary outcome, not the other way around.",
      },
      {
        heading: "Define variables clearly",
        body:
          "Specify outcomes, exposures, covariates, coding rules and derived variables before analysis.",
      },
      {
        heading: "Plan missing data handling",
        body:
          "State how missing data will be described and handled in the main and sensitivity analyses.",
      },
      {
        heading: "Predefine subgroup and sensitivity analyses",
        body:
          "Subgroup analyses should be justified in advance to avoid selective interpretation.",
      },
    ],
    checklist: [
      "State study aim and hypotheses.",
      "Define primary and secondary outcomes.",
      "Describe inclusion/exclusion rules.",
      "Specify statistical methods.",
      "Plan missing data handling.",
      "Define tables and figures to produce.",
    ],
  },

  "report-regression-results-dissertation": {
    title: "How to report regression results in a dissertation",
    tag: "Research support",
    level: "Intermediate",
    description:
      "A guide to writing regression methods, tables, coefficients, confidence intervals and interpretation clearly.",
    intro:
      "Regression results should be reported as part of a clear story: research question, model choice, variables, estimates, uncertainty and interpretation.",
    keyTerms: [
      {
        term: "Coefficient",
        meaning:
          "The estimated change in outcome associated with a predictor, depending on the model type.",
      },
      {
        term: "Adjusted estimate",
        meaning:
          "An estimate after accounting for other variables in the model.",
      },
      {
        term: "Reference category",
        meaning:
          "The category against which other categories are compared.",
      },
    ],
    sections: [
      {
        heading: "Explain the model choice",
        body:
          "State why the regression model fits the outcome type and research question.",
      },
      {
        heading: "Describe variables",
        body:
          "Clearly identify the outcome, predictors, covariates and reference categories.",
      },
      {
        heading: "Report estimates with uncertainty",
        body:
          "Include coefficients or ratios with confidence intervals and p-values where appropriate.",
      },
      {
        heading: "Interpret in context",
        body:
          "Explain what the estimate means for the research question. Avoid simply copying the software output.",
      },
    ],
    checklist: [
      "Name the regression model used.",
      "Define outcome and predictors.",
      "State reference categories.",
      "Report estimates with confidence intervals.",
      "Explain adjusted vs unadjusted models.",
      "Connect findings to the research question.",
    ],
  },

  "confounding-mediation-effect-modification": {
    title: "Confounding, mediation and effect modification",
    tag: "Epidemiology",
    level: "Advanced",
    description:
      "A conceptual guide to three common ideas students meet in epidemiology, medical statistics and social research.",
    intro:
      "Confounding, mediation and effect modification are related but different ideas. Mixing them up can lead to incorrect adjustment and weak interpretation.",
    keyTerms: [
      {
        term: "Confounding",
        meaning:
          "A distortion of the exposure-outcome association by a third variable related to both.",
      },
      {
        term: "Mediation",
        meaning:
          "A pathway through which an exposure may affect an outcome.",
      },
      {
        term: "Effect modification",
        meaning:
          "When the effect differs across levels of another variable.",
      },
    ],
    sections: [
      {
        heading: "Confounders should often be adjusted for",
        body:
          "Confounding can create or hide associations. Adjustment should be based on subject knowledge and study design, not only statistical significance.",
      },
      {
        heading: "Mediators are part of the pathway",
        body:
          "Adjusting for a mediator can change the meaning of the estimate because it may block part of the effect.",
      },
      {
        heading: "Effect modification is not a nuisance",
        body:
          "If an effect differs by subgroup, this may be a key finding rather than something to adjust away.",
      },
      {
        heading: "Draw the assumed relationship",
        body:
          "A simple causal diagram can help decide whether a variable is a confounder, mediator or modifier.",
      },
    ],
    checklist: [
      "Define exposure and outcome.",
      "Identify possible confounders.",
      "Avoid adjusting for mediators without clear reason.",
      "Consider interaction/effect modification.",
      "Use subject knowledge, not only p-values.",
      "Explain adjustment decisions.",
    ],
  },

  "causal-inference-dags-introduction": {
    title: "Introduction to causal inference and DAGs",
    tag: "Causal inference",
    level: "Advanced",
    description:
      "A beginner-to-intermediate guide to causal questions, confounder selection, directed acyclic graphs and adjustment.",
    intro:
      "Causal inference asks what would happen under a different exposure or intervention. DAGs help make assumptions visible before deciding what to adjust for.",
    keyTerms: [
      {
        term: "DAG",
        meaning:
          "A directed acyclic graph showing assumed causal relationships between variables.",
      },
      {
        term: "Confounder",
        meaning:
          "A variable that affects both exposure and outcome and may distort the association.",
      },
      {
        term: "Collider",
        meaning:
          "A variable affected by two other variables; adjusting for it can introduce bias.",
      },
    ],
    sections: [
      {
        heading: "Start with a causal question",
        body:
          "A causal question asks about the effect of changing an exposure or intervention, not just whether two variables are associated.",
      },
      {
        heading: "DAGs show assumptions",
        body:
          "A DAG does not prove causality. It records what you believe about the relationships between variables.",
      },
      {
        heading: "Adjustment is not automatic",
        body:
          "Some variables should be adjusted for, while others should not. DAGs can help avoid overadjustment and collider bias.",
      },
      {
        heading: "Causal language needs caution",
        body:
          "Use causal wording only when study design, assumptions and analysis support it.",
      },
    ],
    checklist: [
      "Write the causal question clearly.",
      "Identify exposure and outcome.",
      "Draw assumed relationships.",
      "Select confounders carefully.",
      "Avoid adjusting for colliders.",
      "State assumptions transparently.",
    ],
  },

  "model-validation-overfitting-cross-validation": {
    title: "Model validation: overfitting, train-test split and cross-validation",
    tag: "Data science",
    level: "Advanced",
    description:
      "A practical guide to evaluating prediction models and avoiding overly optimistic performance estimates.",
    intro:
      "Prediction models can look excellent on the data used to build them but perform poorly on new data. Validation checks how well a model generalises.",
    keyTerms: [
      {
        term: "Overfitting",
        meaning:
          "When a model learns patterns specific to the training data rather than general patterns.",
      },
      {
        term: "Train-test split",
        meaning:
          "Dividing data into one part for model building and another for testing performance.",
      },
      {
        term: "Cross-validation",
        meaning:
          "Repeatedly splitting data into training and validation folds to estimate performance.",
      },
    ],
    sections: [
      {
        heading: "Training performance is not enough",
        body:
          "A model should be assessed on data not used to fit it. Otherwise performance may be overly optimistic.",
      },
      {
        heading: "Avoid data leakage",
        body:
          "Preprocessing steps such as scaling, imputation and feature selection should be done within the training process, not using the full dataset before splitting.",
      },
      {
        heading: "Use suitable performance metrics",
        body:
          "Classification, regression and survival prediction require different metrics. Accuracy alone may be misleading for imbalanced outcomes.",
      },
      {
        heading: "Report validation clearly",
        body:
          "State how the model was split, tuned, validated and evaluated. Transparent reporting improves trust.",
      },
    ],
    checklist: [
      "Separate training and testing where possible.",
      "Avoid data leakage.",
      "Use cross-validation for model tuning.",
      "Report all performance metrics clearly.",
      "Check calibration where relevant.",
      "Do not report training performance as final performance.",
    ],
  },

  "roc-sensitivity-specificity-auc": {
    title: "ROC curves, sensitivity, specificity and AUC",
    tag: "Biostatistics",
    level: "Intermediate",
    description:
      "A guide to diagnostic test evaluation and classification model performance in health and data science.",
    intro:
      "ROC curves and related metrics are commonly used for diagnostic tests and classification models. They help summarise how well a test separates people with and without an outcome.",
    keyTerms: [
      {
        term: "Sensitivity",
        meaning:
          "The proportion of true positives correctly identified.",
      },
      {
        term: "Specificity",
        meaning:
          "The proportion of true negatives correctly identified.",
      },
      {
        term: "AUC",
        meaning:
          "Area under the ROC curve; a summary of discrimination across thresholds.",
      },
    ],
    sections: [
      {
        heading: "Sensitivity and specificity depend on threshold",
        body:
          "Changing the cut-off can increase sensitivity but reduce specificity, or vice versa.",
      },
      {
        heading: "ROC curves show threshold trade-offs",
        body:
          "An ROC curve plots sensitivity against 1-specificity across possible thresholds.",
      },
      {
        heading: "AUC summarises discrimination",
        body:
          "AUC describes how well the model separates cases from non-cases, but it does not show calibration.",
      },
      {
        heading: "Choose thresholds based on context",
        body:
          "The best threshold depends on the consequences of false positives and false negatives.",
      },
    ],
    checklist: [
      "Define positive and negative outcome clearly.",
      "Report sensitivity and specificity.",
