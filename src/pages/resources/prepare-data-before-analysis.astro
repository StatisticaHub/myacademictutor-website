---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const checklist = [
  "Check variable names are clear and consistent",
  "Confirm each variable has the correct data type",
  "Look for impossible or unrealistic values",
  "Check missing values and decide how to handle them",
  "Identify potential outliers and decide whether they are errors or real values",
  "Recode categorical variables clearly",
  "Create derived variables only when justified",
  "Run basic descriptive statistics before modelling",
  "Keep a record of every cleaning decision",
];
---

<BaseLayout
  title="How to prepare your data before analysis | My Academic Tutor"
  description="A student-friendly checklist for preparing data before statistical analysis."
>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto max-w-5xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Data analysis guide
        </p>

        <h1 class="mt-4 text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
          How to prepare your data before analysis.
        </h1>

        <p class="mt-7 text-lg leading-8 text-neutral-700">
          Good analysis starts before the statistical test or model. Clean,
          well-documented data makes your results easier to trust and explain.
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.75fr_1.25fr]">
        <aside>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Checklist
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950">
            Screen before you model.
          </h2>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            Missing values, outliers, coding errors and unclear variables can
            affect your final conclusions.
          </p>
        </aside>

        <div class="grid gap-5">
          {checklist.map((item) => (
            <div class="border border-neutral-200 bg-[#f8f6f2] px-5 py-4">
              <p class="text-sm leading-6 text-neutral-700">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#f8f6f2] px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-3">
        <article class="border border-neutral-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-neutral-950">Missing values</h2>
          <p class="mt-3 text-sm leading-6 text-neutral-600">
            Do not simply delete missing data without thinking. First check how
            much is missing, which variables are affected and whether the
            missingness may be related to the outcome or group.
          </p>
        </article>

        <article class="border border-neutral-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-neutral-950">Outliers</h2>
          <p class="mt-3 text-sm leading-6 text-neutral-600">
            Outliers can be data-entry errors, measurement issues or genuine
            extreme observations. Investigate them before deciding whether to
            keep, correct or exclude them.
          </p>
        </article>

        <article class="border border-neutral-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-neutral-950">Documentation</h2>
          <p class="mt-3 text-sm leading-6 text-neutral-600">
            Keep a clear record of data-cleaning decisions. This helps when
            writing the methodology section and makes your analysis more
            reproducible.
          </p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
<section class="bg-white px-6 py-16 md:px-10 lg:px-20">
  <div class="mx-auto max-w-4xl border-t border-neutral-200 pt-10">
    <h2 class="text-3xl font-semibold tracking-tight text-neutral-950">
      Need help applying this to your own work?
    </h2>

    <p class="mt-4 text-lg leading-8 text-neutral-700">
      Share your topic, dataset, software requirement and deadline. We can help
      you understand the method, plan the analysis and interpret the results.
    </p>

    <a
      href={`${base}contact`}
      class="mt-8 inline-flex rounded-sm bg-[#8C1515] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#6f1111]"
    >
      Submit requirement
    </a>
  </div>
</section>