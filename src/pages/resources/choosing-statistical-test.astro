---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const tests = [
  ["Compare two independent group means", "Independent samples t-test", "Continuous outcome, two independent groups, approximately normal outcome"],
  ["Compare two related measurements", "Paired t-test", "Continuous outcome measured twice on the same individuals"],
  ["Compare three or more group means", "One-way ANOVA", "Continuous outcome, one categorical grouping variable with 3+ groups"],
  ["Association between two categorical variables", "Chi-square test", "Two categorical variables, expected counts reasonably large"],
  ["Relationship between two continuous variables", "Correlation", "Two continuous variables; use Pearson or Spearman depending on assumptions"],
  ["Predict a continuous outcome", "Linear regression", "Continuous outcome and one or more predictors"],
  ["Predict a binary outcome", "Logistic regression", "Binary outcome such as yes/no or disease/no disease"],
  ["Non-normal or ordinal group comparison", "Non-parametric tests", "Mann–Whitney U, Wilcoxon signed-rank or Kruskal–Wallis depending on design"],
];
---

<BaseLayout
  title="How to choose the correct statistical test | My Academic Tutor"
  description="A practical student guide to choosing between t-tests, ANOVA, chi-square tests, correlation, regression and non-parametric methods."
>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto max-w-5xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Statistics guide
        </p>

        <h1 class="mt-4 text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
          How to choose the correct statistical test.
        </h1>

        <p class="mt-7 text-lg leading-8 text-neutral-700">
          The right test depends on your research question, outcome type,
          number of groups, study design and assumptions. Do not choose a test
          only because it is familiar.
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.75fr_1.25fr]">
        <aside>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Quick logic
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950">
            Start with the question.
          </h2>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            Ask what you want to do: compare groups, test association, predict an
            outcome, or describe a pattern.
          </p>

          <a
            href={`${base}contact`}
            class="mt-8 inline-flex rounded-sm bg-[#8C1515] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#6f1111]"
          >
            Need help choosing?
          </a>
        </aside>

        <div class="grid gap-8">
          <article class="border border-neutral-200 bg-[#f8f6f2] p-6">
            <h2 class="text-2xl font-semibold text-neutral-950">
              Step 1: Identify your outcome variable
            </h2>
            <p class="mt-3 text-sm leading-6 text-neutral-700">
              Is your main outcome continuous, categorical, binary, ordinal or
              time-to-event? The outcome type strongly affects the choice of
              method.
            </p>
          </article>

          <article class="border border-neutral-200 bg-[#f8f6f2] p-6">
            <h2 class="text-2xl font-semibold text-neutral-950">
              Step 2: Identify your comparison or relationship
            </h2>
            <p class="mt-3 text-sm leading-6 text-neutral-700">
              Are you comparing two groups, comparing more than two groups,
              measuring association, or building a prediction/explanation model?
            </p>
          </article>

          <article class="border border-neutral-200 bg-[#f8f6f2] p-6">
            <h2 class="text-2xl font-semibold text-neutral-950">
              Step 3: Check the study design
            </h2>
            <p class="mt-3 text-sm leading-6 text-neutral-700">
              Independent samples, paired/repeated measures and longitudinal
              designs require different methods. A paired design should not be
              analysed like independent groups.
            </p>
          </article>

          <article class="border border-neutral-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-semibold text-neutral-950">
              Common student examples
            </h2>

            <div class="mt-5 overflow-x-auto">
              <table class="w-full border-collapse text-left text-sm">
                <thead>
                  <tr class="border-b border-neutral-300">
                    <th class="py-3 pr-4 font-semibold text-neutral-950">Question</th>
                    <th class="py-3 pr-4 font-semibold text-neutral-950">Possible test</th>
                    <th class="py-3 pr-4 font-semibold text-neutral-950">Typical situation</th>
                  </tr>
                </thead>
                <tbody>
                  {tests.map((row) => (
                    <tr class="border-b border-neutral-200">
                      <td class="py-3 pr-4 text-neutral-700">{row[0]}</td>
                      <td class="py-3 pr-4 text-neutral-700">{row[1]}</td>
                      <td class="py-3 pr-4 text-neutral-700">{row[2]}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>

          <article class="border border-neutral-200 bg-[#f8f6f2] p-6">
            <h2 class="text-2xl font-semibold text-neutral-950">
              Final reminder
            </h2>
            <p class="mt-3 text-sm leading-6 text-neutral-700">
              A test-selection table is only a starting point. You still need to
              check assumptions, sample size, missing data, outliers and whether
              the method answers your research question.
            </p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
<section class="bg-white px-6 py-16 md:px-10 lg:px-20">
  <div class="mx-auto max-w-4xl border-t border-neutral-200 pt-10">
    <h2 class="text-3xl font-semibold tracking-tight text-neutral-950">
      Need help applying this to your own work?
    </h2>

    <p class="mt-4 text-lg leading-8 text-neutral-700">
      Share your topic, dataset, software requirement and deadline. We can help
      you understand the method, plan the analysis and interpret the results.
    </p>

    <a
      href={`${base}contact`}
      class="mt-8 inline-flex rounded-sm bg-[#8C1515] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#6f1111]"
    >
      Submit requirement
    </a>
  </div>
</section>