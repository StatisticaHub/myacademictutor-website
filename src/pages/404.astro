---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Page Not Found | My Academic Tutor"
  description="The page you are looking for could not be found."
>
  <Header />

  <main class="bg-[#f8f6f2] px-6 pb-24 pt-36 md:px-10 lg:px-20">
    <section class="mx-auto max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
        404
      </p>

      <h1 class="mt-4 text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
        Page not found.
      </h1>

      <p class="mt-6 text-lg leading-8 text-neutral-700">
        The page may have moved, or the link may be incorrect. You can return to
        the homepage or explore the main support areas.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href={base}
          class="rounded-sm bg-[#8C1515] px-7 py-4 font-medium text-white transition hover:bg-[#6f1111]"
        >
          Go to homepage
        </a>

        <a
          href={`${base}services`}
          class="rounded-sm border border-neutral-300 bg-white px-7 py-4 font-medium text-neutral-950 transition hover:border-[#8C1515] hover:text-[#8C1515]"
        >
          View services
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>