---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";

const courses = [
  {
    title: "Core Statistics",
    status: "Planned course",
    level: "Foundation to advanced",
    description:
      "A structured course pathway covering the essential statistical ideas needed for university study, research projects and applied data analysis.",
    modules: [
      "Probability and distributions",
      "Statistical inference",
      "Hypothesis testing",
      "Correlation and regression",
      "Generalised linear models",
      "Multivariate methods",
      "Time series",
      "Bayesian statistics",
    ],
    software: ["R", "SPSS", "Stata"],
  },
  {
    title: "Biostatistics & Medical Statistics",
    status: "Planned course",
    level: "Intermediate to advanced",
    description:
      "A health-data focused course area for students and researchers working with clinical, epidemiological and biomedical datasets.",
    modules: [
      "Study design",
      "Epidemiological measures",
      "Logistic regression",
      "Survival analysis",
      "Clinical trials",
      "Sample size calculation",
      "Diagnostic test evaluation",
      "Meta-analysis",
    ],
    software: ["R", "Stata", "SPSS", "SAS"],
  },
  {
    title: "R for Academic Data Analysis",
    status: "Priority course",
    level: "Beginner to advanced",
    description:
      "A practical R course for students who need to clean data, analyse results, create plots and prepare reproducible academic reports.",
    modules: [
      "R and RStudio basics",
      "Data import and cleaning",
      "tidyverse workflows",
      "ggplot2 visualisation",
      "Statistical testing in R",
      "Regression models in R",
      "R Markdown / Quarto",
      "Project organisation",
    ],
    software: ["R", "RStudio", "Quarto"],
  },
  {
    title: "Python for Data Science",
    status: "Planned course",
    level: "Beginner to intermediate",
    description:
      "A Python course focused on practical data handling, analysis, visualisation and machine learning foundations.",
    modules: [
      "Python basics",
      "NumPy and pandas",
      "Data cleaning",
      "Exploratory analysis",
      "Visualisation",
      "Statistical analysis",
      "Machine learning basics",
      "Model evaluation",
    ],
    software: ["Python", "pandas", "scikit-learn"],
  },
  {
    title: "Bioinformatics & Omics Data Analysis",
    status: "Planned course",
    level: "Intermediate",
    description:
      "A course pathway for biological data analysis, gene expression workflows and interpretation of computational biology outputs.",
    modules: [
      "Omics data basics",
      "RNA-seq concepts",
      "Gene expression analysis",
      "Differential expression",
      "Bioconductor workflows",
      "Single-cell concepts",
      "Pathway analysis",
      "Biological interpretation",
    ],
    software: ["R", "Bioconductor"],
  },
  {
    title: "Dissertation & Research Project Data Analysis",
    status: "Guided support",
    level: "Project-based",
    description:
      "A guided support pathway for students working on dissertations, theses, research reports or applied data-analysis projects.",
    modules: [
      "Research question refinement",
      "Variable and outcome planning",
      "Method selection",
      "Data cleaning plan",
      "Analysis workflow",
      "Results interpretation",
      "Tables and figures",
      "Methodology and results writing",
    ],
    software: ["R", "Python", "SPSS", "SAS", "Stata"],
  },
];
---

<BaseLayout
  title="Courses | My Academic Tutor"
  description="Courses in statistics, biostatistics, R, Python, SPSS, SAS, Stata, bioinformatics, data science and dissertation analysis."
>
  <Header />

  <main>
    <section class="relative overflow-hidden px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(34,211,238,0.16),transparent_35%),radial-gradient(circle_at_left,rgba(99,102,241,0.12),transparent_35%)]"></div>

      <div class="relative mx-auto max-w-5xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
          Courses
        </p>

        <h1 class="mt-4 text-5xl font-semibold tracking-tight md:text-6xl">
          Organised learning pathways for quantitative subjects.
        </h1>

        <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-300">
          Courses are being organised around clear explanation, worked examples,
          software demonstrations, exercises and practical academic application.
        </p>
      </div>
    </section>

    <section class="px-6 pb-24 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-2">
        {courses.map((course) => (
          <article class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6 transition hover:border-cyan-300/30">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm font-semibold text-cyan-300">{course.status}</p>
                <h2 class="mt-2 text-2xl font-semibold">{course.title}</h2>
                <p class="mt-2 text-sm text-slate-400">{course.level}</p>
              </div>

              <a
                href="/contact"
                class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-white transition hover:border-cyan-300/40 hover:bg-white/[0.08]"
              >
                Enquire
              </a>
            </div>

            <p class="mt-5 text-sm leading-6 text-slate-400">
              {course.description}
            </p>

            <div class="mt-6">
              <p class="text-sm font-semibold text-slate-200">
                Indicative topics
              </p>

              <div class="mt-3 grid gap-2 sm:grid-cols-2">
                {course.modules.map((module) => (
                  <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3">
                    <span class="h-1.5 w-1.5 rounded-full bg-cyan-300"></span>
                    <span class="text-sm text-slate-300">{module}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-6 flex flex-wrap gap-2">
              {course.software.map((tool) => (
                <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-3 py-1 text-xs text-cyan-100">
                  {tool}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-white/10 bg-white/[0.03] px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
            Course format
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight">
            Designed for structured academic learning.
          </h2>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <div class="rounded-[2rem] border border-white/10 bg-slate-950/70 p-6">
            <h3 class="text-xl font-semibold">Concepts</h3>
            <p class="mt-3 text-sm leading-6 text-slate-400">
              Clear explanation of the underlying statistical or computational ideas.
            </p>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-slate-950/70 p-6">
            <h3 class="text-xl font-semibold">Software</h3>
            <p class="mt-3 text-sm leading-6 text-slate-400">
              Practical demonstrations using tools such as R, Python, SPSS, SAS and Stata.
            </p>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-slate-950/70 p-6">
            <h3 class="text-xl font-semibold">Application</h3>
            <p class="mt-3 text-sm leading-6 text-slate-400">
              Worked examples, interpretation and reporting for academic or research contexts.
            </p>
          </div>
        </div>
      </div>
    </section>

    <ContactCTA />
  </main>

  <Footer />
</BaseLayout>