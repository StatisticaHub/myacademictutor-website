---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const courses = [
  {
    title: "Core Statistics",
    status: "Planned course",
    level: "Foundation to advanced",
    description:
      "A structured pathway covering essential statistical ideas for university study, research projects and applied data analysis.",
    modules: [
      "Probability and distributions",
      "Statistical inference",
      "Hypothesis testing",
      "Correlation and regression",
      "Generalised linear models",
      "Multivariate methods",
      "Time series",
      "Bayesian statistics",
    ],
    software: ["R", "SPSS", "Stata"],
  },
  {
    title: "Biostatistics & Medical Statistics",
    status: "Planned course",
    level: "Intermediate to advanced",
    description:
      "A health-data focused pathway for clinical, epidemiological and biomedical data-analysis topics.",
    modules: [
      "Study design",
      "Epidemiological measures",
      "Logistic regression",
      "Survival analysis",
      "Clinical trials",
      "Sample size calculation",
      "Diagnostic test evaluation",
      "Meta-analysis",
    ],
    software: ["R", "Stata", "SPSS", "SAS"],
  },
  {
    title: "R for Academic Data Analysis",
    status: "Priority course",
    level: "Beginner to advanced",
    description:
      "A practical R pathway for students who need to clean data, analyse results, create plots and prepare reproducible academic reports.",
    modules: [
      "R and RStudio basics",
      "Data import and cleaning",
      "tidyverse workflows",
      "ggplot2 visualisation",
      "Statistical testing in R",
      "Regression models in R",
      "R Markdown / Quarto",
      "Project organisation",
    ],
    software: ["R", "RStudio", "Quarto"],
  },
  {
    title: "Python for Data Science",
    status: "Planned course",
    level: "Beginner to intermediate",
    description:
      "A Python pathway focused on data handling, analysis, visualisation and machine learning foundations.",
    modules: [
      "Python basics",
      "NumPy and pandas",
      "Data cleaning",
      "Exploratory analysis",
      "Visualisation",
      "Statistical analysis",
      "Machine learning basics",
      "Model evaluation",
    ],
    software: ["Python", "pandas", "scikit-learn"],
  },
  {
    title: "Bioinformatics & Omics Data Analysis",
    status: "Planned course",
    level: "Intermediate",
    description:
      "A pathway for biological data analysis, gene expression workflows and interpretation of computational biology outputs.",
    modules: [
      "Omics data basics",
      "RNA-seq concepts",
      "Gene expression analysis",
      "Differential expression",
      "Bioconductor workflows",
      "Single-cell concepts",
      "Pathway analysis",
      "Biological interpretation",
    ],
    software: ["R", "Bioconductor"],
  },
  {
    title: "Dissertation & Research Project Data Analysis",
    status: "Guided support",
    level: "Project-based",
    description:
      "A guided support pathway for dissertations, theses, research reports and applied data-analysis projects.",
    modules: [
      "Research question refinement",
      "Variable and outcome planning",
      "Method selection",
      "Data cleaning plan",
      "Analysis workflow",
      "Results interpretation",
      "Tables and figures",
      "Methodology and results writing",
    ],
    software: ["R", "Python", "SPSS", "SAS", "Stata"],
  },
];
---

<BaseLayout
  title="Courses | My Academic Tutor"
  description="Courses and learning pathways in statistics, biostatistics, R, Python, SPSS, SAS, Stata, bioinformatics, data science and dissertation analysis."
>
  <Header />

  <main>
    <section class="bg-[#f8f6f2] px-6 pb-20 pt-36 md:px-10 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Courses
        </p>

        <h1 class="mt-4 max-w-5xl text-5xl font-semibold tracking-tight text-neutral-950 md:text-6xl">
          Organised learning pathways for quantitative subjects.
        </h1>

        <p class="mt-7 max-w-3xl text-lg leading-8 text-neutral-700">
          Courses are being organised around clear explanation, worked examples,
          software demonstrations, exercises and practical academic application.
        </p>
      </div>
    </section>

    <section class="bg-white px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Pathways
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
            Explore by subject area.
          </h2>

          <p class="mt-5 text-lg leading-8 text-neutral-700">
            Open each pathway to view indicative topics, software and support
            structure. Students can enquire even if their exact topic is not
            listed.
          </p>

          <a
            href={`${base}contact`}
            class="mt-8 inline-flex rounded-sm bg-[#8C1515] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#6f1111]"
          >
            Submit requirement
          </a>
        </div>

        <div class="border-y border-neutral-300">
          {courses.map((course, index) => (
            <details
              class="group border-b border-neutral-200 py-6 last:border-b-0"
              open={index === 0}
            >
              <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
                <div>
                  <p class="text-sm font-medium text-[#8C1515]">
                    {course.status} · {course.level}
                  </p>

                  <h3 class="mt-2 text-2xl font-semibold tracking-tight text-neutral-950">
                    {course.title}
                  </h3>

                  <p class="mt-3 max-w-2xl text-sm leading-6 text-neutral-600">
                    {course.description}
                  </p>
                </div>

                <span class="mt-2 text-2xl leading-none text-[#8C1515] transition group-open:rotate-45">
                  +
                </span>
              </summary>

              <div class="mt-6 grid gap-6 md:grid-cols-[1.1fr_0.9fr]">
                <div>
                  <p class="text-sm font-semibold text-neutral-950">
                    Indicative topics
                  </p>

                  <div class="mt-3 grid gap-2 sm:grid-cols-2">
                    {course.modules.map((module) => (
                      <div class="border border-neutral-200 bg-[#f8f6f2] px-4 py-3">
                        <span class="text-sm text-neutral-700">{module}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div>
                  <p class="text-sm font-semibold text-neutral-950">
                    Software and tools
                  </p>

                  <div class="mt-3 flex flex-wrap gap-2">
                    {course.software.map((tool) => (
                      <span class="border border-neutral-300 bg-white px-3 py-1 text-xs text-neutral-700">
                        {tool}
                      </span>
                    ))}
                  </div>

                  <a
                    href={`${base}contact`}
                    class="mt-6 inline-flex rounded-sm border border-neutral-300 bg-white px-5 py-3 text-sm font-medium text-neutral-950 transition hover:border-[#8C1515] hover:text-[#8C1515]"
                  >
                    Enquire about this pathway
                  </a>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#f8f6f2] px-6 py-20 md:px-10 lg:px-20">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
            Course format
          </p>

          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950">
            Structured around understanding, software and application.
          </h2>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <div class="border border-neutral-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-neutral-950">Concepts</h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600">
              Clear explanation of the underlying statistical or computational ideas.
            </p>
          </div>

          <div class="border border-neutral-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-neutral-950">Software</h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600">
              Practical demonstrations using tools such as R, Python, SPSS, SAS and Stata.
            </p>
          </div>

          <div class="border border-neutral-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-neutral-950">Application</h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600">
              Worked examples, interpretation and reporting for academic or research contexts.
            </p>
          </div>
        </div>
      </div>
    </section>

    <ContactCTA />
  </main>

  <Footer />
</BaseLayout>