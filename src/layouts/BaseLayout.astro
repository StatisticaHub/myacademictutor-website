---
import "../styles/global.css";

const {
  title = "My Academic Tutor | Academic Tutoring & Research Support",
  description = "An academic tutoring team supporting students and researchers across statistics, biostatistics, programming, data science, bioinformatics and quantitative research.",
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const siteUrl = "https://statisticahub.github.io";
const canonicalUrl = `${siteUrl}${base}`;
const logoUrl = `${siteUrl}${base}logo.png`;
const ogImage = `${siteUrl}${base}images/hero-research.jpg`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "My Academic Tutor",
  url: canonicalUrl,
  logo: logoUrl,
  email: "contact@myacademictutor.com",
  description,
  founder: {
    "@type": "Person",
    name: "Rahul",
    alumniOf: {
      "@type": "CollegeOrUniversity",
      name: "Indian Institute of Technology Kanpur",
    },
    knowsAbout: [
      "Statistics",
      "Medical Statistics",
      "Health Data Science",
      "Biostatistics",
      "Data Science",
    ],
  },
  sameAs: [
    "https://www.linkedin.com/company/myacademictutor/",
    "https://www.youtube.com/@StatisticaHub",
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta name="author" content="My Academic Tutor" />
    <meta
      name="keywords"
      content="academic tutoring, statistics tutor, biostatistics tutor, medical statistics, R programming, Python tutor, SPSS, SAS, Stata, data science tutor, bioinformatics tutor, dissertation data analysis, research support"
    />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${base}logo.png`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="My Academic Tutor" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>

  <body class="bg-[#f8f6f2] text-neutral-950 antialiased">
    <slot />
  </body>
</html>