---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="px-6 pb-24 pt-36 md:px-10 lg:px-20">
  <div class="mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
    <div>
      <p class="mb-6 inline-flex rounded-full border border-neutral-300 bg-white px-4 py-2 text-sm text-neutral-600">
        Statistics · Biostatistics · Programming · Bioinformatics · Data Science
      </p>

      <h1 class="max-w-4xl text-5xl font-semibold leading-[1.02] tracking-tight text-neutral-950 md:text-7xl">
        Academic support for quantitative and data-driven subjects.
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-8 text-neutral-600">
        My Academic Tutor has mentored students globally since 2020, providing
        structured support in statistics, biostatistics, R, Python, SPSS, SAS,
        Stata, bioinformatics, data science and quantitative research methods.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href={`${base}courses`}
          class="rounded-full bg-neutral-950 px-7 py-4 text-center font-medium text-white transition hover:bg-neutral-800"
        >
          View Courses
        </a>

        <a
          href={`${base}contact`}
          class="rounded-full border border-neutral-300 bg-white px-7 py-4 text-center font-medium text-neutral-950 transition hover:border-neutral-950"
        >
          Submit a Requirement
        </a>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-3">
        <div class="border-t border-neutral-300 pt-4">
          <p class="text-2xl font-semibold text-neutral-950">1:1</p>
          <p class="mt-1 text-sm text-neutral-500">Academic guidance</p>
        </div>

        <div class="border-t border-neutral-300 pt-4">
          <p class="text-2xl font-semibold text-neutral-950">R/Python</p>
          <p class="mt-1 text-sm text-neutral-500">Code-based learning</p>
        </div>

        <div class="border-t border-neutral-300 pt-4">
          <p class="text-2xl font-semibold text-neutral-950">Research</p>
          <p class="mt-1 text-sm text-neutral-500">Project support</p>
        </div>
      </div>
    </div>

    <div class="rounded-[2rem] border border-neutral-200 bg-white p-3 shadow-sm">
      <div class="relative min-h-[520px] overflow-hidden rounded-[1.5rem]">
        <img
          src={`${base}images/hero-research.jpg`}
          alt="Researchers reviewing data analysis on computer screens"
          class="absolute inset-0 h-full w-full object-cover grayscale"
        />

        <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/35 to-transparent"></div>

        <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
          <p class="text-sm uppercase tracking-[0.28em] text-neutral-300">
            Learning pathway
          </p>

          <h2 class="mt-4 text-4xl font-semibold">
            Quantitative Research Support
          </h2>

          <p class="mt-4 max-w-md text-neutral-200">
            Support across concepts, software, analysis planning, interpretation
            and academic reporting.
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            <span class="rounded-full border border-white/25 bg-white/10 px-3 py-1 text-xs text-white">
              Statistics
            </span>
            <span class="rounded-full border border-white/25 bg-white/10 px-3 py-1 text-xs text-white">
              Medical statistics
            </span>
            <span class="rounded-full border border-white/25 bg-white/10 px-3 py-1 text-xs text-white">
              R / Python
            </span>
            <span class="rounded-full border border-white/25 bg-white/10 px-3 py-1 text-xs text-white">
              Research projects
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>