---
const supportAreas = [
  "Statistics and probability",
  "Biostatistics and medical statistics",
  "R, Python, SPSS, SAS and Stata",
  "Data science and machine learning",
  "Bioinformatics and omics",
  "Dissertation and research projects",
];

const countries = [
  "India",
  "USA",
  "Canada",
  "Australia",
  "Italy",
  "UAE",
  "Ireland",
  "UK",
  "South Korea",
  "Singapore",
  "Kuwait",
];
---

<section class="bg-white px-6 py-20 md:px-10 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Student support record
        </p>

        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
          Supporting students across countries and subjects.
        </h2>

        <p class="mt-5 text-lg leading-8 text-neutral-700">
          We have supported students based in India, USA, Canada, Australia,
          Italy, UAE, Ireland, UK, South Korea, Singapore and Kuwait.
        </p>

        <p class="mt-5 text-sm leading-6 text-neutral-500">
          Instead of displaying personal student messages publicly, we keep
          feedback anonymised and focus on the types of academic support
          students commonly request.
        </p>
      </div>

      <div class="grid gap-8">
        <div>
          <h3 class="text-xl font-semibold tracking-tight text-neutral-950">
            Common support areas
          </h3>

          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {supportAreas.map((item) => (
              <div class="border border-neutral-200 bg-[#f8f6f2] px-4 py-3">
                <span class="text-sm text-neutral-700">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-xl font-semibold tracking-tight text-neutral-950">
            Student locations
          </h3>

          <div class="mt-5 flex flex-wrap gap-2">
            {countries.map((country) => (
              <span class="border border-neutral-200 bg-[#f8f6f2] px-3 py-2 text-sm text-neutral-700">
                {country}
              </span>
            ))}
          </div>
        </div>

        <div class="border-l-4 border-[#8C1515] bg-[#f8f6f2] p-5">
          <p class="text-sm leading-6 text-neutral-700">
            Student privacy is important to us. Public examples are kept
            general unless a student gives clear permission to share identifiable
            feedback.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>