---
const items = [
  {
    area: "Statistics",
    title: "Regression and model interpretation",
    description:
      "Support with selecting a suitable regression approach, checking assumptions and explaining results clearly.",
  },
  {
    area: "Biostatistics",
    title: "Survival analysis workflow",
    description:
      "Guidance on Kaplan-Meier curves, Cox models, proportional hazards checks and academic reporting.",
  },
  {
    area: "Research support",
    title: "Dissertation analysis planning",
    description:
      "Support with research questions, variable planning, method selection, results interpretation and reporting structure.",
  },
];
---

<section class="bg-white px-6 py-20 md:px-10 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
      Examples
    </p>

    <h2 class="mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
      Typical academic support areas.
    </h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {items.map((item) => (
        <article class="border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-medium text-[#8C1515]">{item.area}</p>

          <h3 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-950">
            {item.title}
          </h3>

          <p class="mt-3 text-sm leading-6 text-neutral-600">
            {item.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>