---
const subjectGroups = [
  {
    title: "Programming & Statistical Software",
    short: "R, Python, SPSS, SAS, Stata and reproducible analysis workflows.",
    description:
      "Support with statistical software, programming, data cleaning, analysis, visualisation and reproducible reporting.",
    items: [
      "R programming",
      "Python for data analysis",
      "SPSS",
      "SAS",
      "Stata",
      "R Markdown / Quarto",
      "Data cleaning",
      "Reproducible analysis",
    ],
  },
  {
    title: "Statistics",
    short: "Core statistical subjects from foundation to advanced level.",
    description:
      "Support for undergraduate, postgraduate and research-level statistical methods.",
    items: [
      "Probability theory",
      "Statistical inference",
      "Hypothesis testing",
      "Regression analysis",
      "Generalised linear models",
      "Multivariate analysis",
      "Time series analysis",
      "Bayesian statistics",
    ],
  },
  {
    title: "Biostatistics & Medical Statistics",
    short: "Health-data methods for clinical and epidemiological research.",
    description:
      "Support with medical statistics, clinical research methods and interpretation of health data.",
    items: [
      "Survival analysis",
      "Clinical trials",
      "Epidemiology",
      "Sample size calculation",
      "Diagnostic test evaluation",
      "Logistic regression",
      "Longitudinal data analysis",
      "Meta-analysis",
    ],
  },
  {
    title: "Data Science & Machine Learning",
    short: "Data preparation, modelling, validation and interpretation.",
    description:
      "Applied data science support from data cleaning to model evaluation and reporting.",
    items: [
      "Data cleaning",
      "Exploratory data analysis",
      "Data visualisation",
      "Machine learning",
      "Classification models",
      "Prediction modelling",
      "Model evaluation",
      "Feature engineering",
    ],
  },
  {
    title: "Bioinformatics & Omics",
    short: "Biological data analysis, gene expression and omics workflows.",
    description:
      "Support with computational biology concepts, omics workflows and biological interpretation.",
    items: [
      "RNA-seq concepts",
      "Gene expression analysis",
      "Differential expression",
      "Bioconductor workflows",
      "Single-cell concepts",
      "Omics data analysis",
      "Pathway analysis",
      "Biological interpretation",
    ],
  },
  {
    title: "Quantitative Research Support",
    short: "Dissertation, thesis and research project analysis support.",
    description:
      "Guidance for planning, analysing, interpreting and presenting academic research.",
    items: [
      "Research design",
      "Dissertation analysis",
      "Survey analysis",
      "Questionnaire data",
      "Results interpretation",
      "Academic reporting",
      "Tables and figures",
      "Methodology writing",
    ],
  },
];
---

<section id="areas" class="border-y border-white/10 bg-white/[0.03] px-6 py-24 md:px-10 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
          Areas of support
        </p>

        <h2 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">
          Subjects organised by category.
        </h2>

        <p class="mt-5 text-lg leading-8 text-slate-300">
          The main areas are grouped clearly so visitors can quickly find the type
          of academic support they need without making the homepage too long.
        </p>

        <a
          href="#contact"
          class="mt-8 inline-flex rounded-full border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
        >
          Discuss your requirement
        </a>
      </div>

      <div class="grid gap-4">
        {subjectGroups.map((group) => (
          <details class="group rounded-[1.5rem] border border-white/10 bg-slate-950/70 p-5 transition hover:border-cyan-300/30">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-5">
              <div>
                <h3 class="text-xl font-semibold">{group.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-400">
                  {group.short}
                </p>
              </div>

              <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/10 text-cyan-300 transition group-open:rotate-45">
                +
              </span>
            </summary>

            <div class="mt-5 border-t border-white/10 pt-5">
              <p class="text-sm leading-6 text-slate-400">
                {group.description}
              </p>

              <div class="mt-5 grid gap-2 sm:grid-cols-2">
                {group.items.map((item) => (
                  <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3">
                    <span class="h-1.5 w-1.5 rounded-full bg-cyan-300"></span>
                    <span class="text-sm text-slate-300">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>