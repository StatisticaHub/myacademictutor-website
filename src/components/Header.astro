---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-neutral-200 bg-[#f8f6f2]/95 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-6 py-4">
    <div class="flex items-center justify-between">
      <a href={base} class="flex items-center gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-sm bg-[#8C1515] text-sm font-semibold tracking-tight text-white">
          MAT
        </div>

        <div>
          <p class="text-base font-semibold leading-tight tracking-tight text-neutral-950">
            My Academic Tutor
          </p>
          <p class="text-xs text-neutral-500">
            Academic tutoring and research support
          </p>
        </div>
      </a>

      <nav class="hidden items-center gap-8 text-sm text-neutral-700 md:flex">
        <a href={`${base}about`} class="transition hover:text-[#8C1515]">About</a>
        <a href={`${base}services`} class="transition hover:text-[#8C1515]">Services</a>
        <a href={`${base}courses`} class="transition hover:text-[#8C1515]">Courses</a>
        <a href={`${base}contact`} class="transition hover:text-[#8C1515]">Contact</a>
      </nav>

      <div class="hidden md:block">
        <a
          href={`${base}contact`}
          class="rounded-sm border border-[#8C1515] bg-[#8C1515] px-5 py-2.5 text-sm font-medium text-white transition hover:bg-[#6f1111]"
        >
          Request Support
        </a>
      </div>

      <button
        id="mobile-menu-button"
        class="rounded-sm border border-neutral-300 bg-white px-4 py-2 text-sm font-medium text-neutral-950 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menu
      </button>
    </div>

    <div id="mobile-menu" class="hidden pt-4 md:hidden">
      <nav class="grid gap-2 border border-neutral-200 bg-white p-4 text-sm text-neutral-700 shadow-sm">
        <a href={`${base}about`} class="px-4 py-3 transition hover:bg-neutral-100 hover:text-[#8C1515]">
          About
        </a>

        <a href={`${base}services`} class="px-4 py-3 transition hover:bg-neutral-100 hover:text-[#8C1515]">
          Services
        </a>

        <a href={`${base}courses`} class="px-4 py-3 transition hover:bg-neutral-100 hover:text-[#8C1515]">
          Courses
        </a>

        <a href={`${base}contact`} class="px-4 py-3 transition hover:bg-neutral-100 hover:text-[#8C1515]">
          Contact
        </a>

        <a
          href={`${base}contact`}
          class="mt-2 bg-[#8C1515] px-5 py-3 text-center font-medium text-white transition hover:bg-[#6f1111]"
        >
          Request Support
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector("#mobile-menu-button");
  const menu = document.querySelector("#mobile-menu");

  button?.addEventListener("click", () => {
    const isOpen = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", String(!isOpen));
    menu?.classList.toggle("hidden");
  });
</script>