---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-white/10 bg-slate-950/85 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-6 py-4">
    <div class="flex items-center justify-between">
      <a href={base} class="flex items-center gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-300 text-sm font-bold text-slate-950">
          MAT
        </div>

        <div>
          <p class="text-lg font-semibold leading-tight">My Academic Tutor</p>
          <p class="text-xs text-slate-400">
            Statistics • Data Science • Bioinformatics
          </p>
        </div>
      </a>

      <nav class="hidden items-center gap-8 text-sm text-slate-300 md:flex">
        <a href={`${base}about`} class="transition hover:text-cyan-300">About</a>
        <a href={`${base}services`} class="transition hover:text-cyan-300">Services</a>
        <a href={`${base}courses`} class="transition hover:text-cyan-300">Courses</a>
        <a href={`${base}contact`} class="transition hover:text-cyan-300">Contact</a>
      </nav>

      <div class="hidden md:block">
        <a
          href={`${base}contact`}
          class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
        >
          Request Support
        </a>
      </div>

      <button
        id="mobile-menu-button"
        class="rounded-2xl border border-white/10 bg-white/[0.05] px-4 py-2 text-sm font-semibold text-white md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menu
      </button>
    </div>

    <div id="mobile-menu" class="hidden pt-4 md:hidden">
      <nav class="grid gap-2 rounded-[1.5rem] border border-white/10 bg-slate-950/95 p-4 text-sm text-slate-300">
        <a href={`${base}about`} class="rounded-2xl px-4 py-3 transition hover:bg-white/[0.06] hover:text-cyan-300">
          About
        </a>

        <a href={`${base}services`} class="rounded-2xl px-4 py-3 transition hover:bg-white/[0.06] hover:text-cyan-300">
          Services
        </a>

        <a href={`${base}courses`} class="rounded-2xl px-4 py-3 transition hover:bg-white/[0.06] hover:text-cyan-300">
          Courses
        </a>

        <a href={`${base}contact`} class="rounded-2xl px-4 py-3 transition hover:bg-white/[0.06] hover:text-cyan-300">
          Contact
        </a>

        <a
          href={`${base}contact`}
          class="mt-2 rounded-full bg-cyan-300 px-5 py-3 text-center font-semibold text-slate-950 transition hover:bg-cyan-200"
        >
          Request Support
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector("#mobile-menu-button");
  const menu = document.querySelector("#mobile-menu");

  button?.addEventListener("click", () => {
    const isOpen = button.getAttribute("aria-expanded") === "true";

    button.setAttribute("aria-expanded", String(!isOpen));
    menu?.classList.toggle("hidden");
  });
</script>