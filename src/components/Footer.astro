---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<footer class="border-t border-neutral-200 bg-neutral-950 px-6 py-12 text-white md:px-10 lg:px-20">
  <div class="mx-auto grid max-w-7xl gap-10 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
    <div>
      <p class="text-lg font-semibold tracking-tight">
        My Academic Tutor
      </p>

      <p class="mt-3 max-w-md text-sm leading-6 text-neutral-300">
        A academic tutoring team supporting students and researchers across
        quantitative, computational and research-focused subjects.
      </p>

      <p class="mt-3 text-sm leading-6 text-neutral-400">
        Founded by Rahul, Founder and Statistics Lead.
      </p>
    </div>

    <div>
      <p class="font-semibold">Pages</p>

      <div class="mt-3 grid gap-2 text-sm text-neutral-300">
        <a href={`${base}about`} class="hover:text-white">About</a>
        <a href={`${base}services`} class="hover:text-white">Services</a>
        <a href={`${base}courses`} class="hover:text-white">Courses</a>
        <a href={`${base}contact`} class="hover:text-white">Contact</a>
      </div>
    </div>

    <div>
      <p class="font-semibold">Contact</p>

      <div class="mt-3 grid gap-2 text-sm text-neutral-300">
        <a href="mailto:contact@myacademictutor.com" class="hover:text-white">
          contact@myacademictutor.com
        </a>
        <span>Online academic support</span>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-10 max-w-7xl border-t border-neutral-800 pt-6">
    <p class="text-sm text-neutral-500">
      © 2026 My Academic Tutor. All rights reserved.
    </p>
  </div>
</footer>