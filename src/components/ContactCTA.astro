---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="bg-white px-6 py-24 md:px-10 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 border-t border-neutral-300 pt-12 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
          Start here
        </p>

        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
          Tell us what you need support with.
        </h2>
      </div>

      <div>
        <p class="max-w-3xl text-lg leading-8 text-neutral-700">
          Share your subject, level, software requirements, deadline and the type
          of support you need. We will suggest the most suitable tutor or support
          route.
        </p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a
            href={`${base}contact`}
            class="rounded-sm bg-[#8C1515] px-7 py-4 text-center font-medium text-white transition hover:bg-[#6f1111]"
          >
            Contact us
          </a>

          <a
            href="mailto:contact@myacademictutor.com"
            class="rounded-sm border border-neutral-300 bg-white px-7 py-4 text-center font-medium text-neutral-950 transition hover:border-[#8C1515] hover:text-[#8C1515]"
          >
            Email directly
          </a>
        </div>
      </div>
    </div>
  </div>
</section>