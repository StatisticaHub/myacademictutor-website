---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="bg-white px-6 py-24 md:px-10 lg:px-20">
  <div class="mx-auto max-w-5xl border-t border-neutral-300 pt-12">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-neutral-500">
      Start here
    </p>

    <h2 class="mt-4 text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
      Tell us what you need support with.
    </h2>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-neutral-600">
      Share your subject, level, software requirements and deadline. We will
      suggest the most suitable tutor or support route.
    </p>

    <div class="mt-9 flex flex-col gap-4 sm:flex-row">
      <a
        href={`${base}contact`}
        class="rounded-full bg-neutral-950 px-7 py-4 text-center font-medium text-white transition hover:bg-neutral-800"
      >
        Contact us
      </a>

      <a
        href="mailto:contact@myacademictutor.com"
        class="rounded-full border border-neutral-300 bg-white px-7 py-4 text-center font-medium text-neutral-950 transition hover:border-neutral-950"
      >
        Email directly
      </a>
    </div>
  </div>
</section>