---
const courses = [
  {
    title: "Core Statistics",
    level: "Foundation to advanced",
    description:
      "Probability, distributions, inference, hypothesis testing, regression, GLMs, multivariate methods and time series.",
    topics: ["Probability", "Inference", "Regression", "Time Series"],
  },
  {
    title: "Biostatistics & Medical Statistics",
    level: "Intermediate to advanced",
    description:
      "Survival analysis, clinical trials, epidemiology, diagnostic studies, longitudinal data and meta-analysis.",
    topics: ["Survival Analysis", "Clinical Trials", "Epidemiology", "Meta-analysis"],
  },
  {
    title: "R, Python, SPSS, SAS & Stata",
    level: "Practical software training",
    description:
      "Software-focused support for data cleaning, statistical analysis, visualisation, reproducible reporting and project workflows.",
    topics: ["R", "Python", "SPSS", "SAS", "Stata"],
  },
  {
    title: "Bioinformatics & Omics Data Analysis",
    level: "Applied biological data analysis",
    description:
      "Gene expression analysis, RNA-seq concepts, Bioconductor workflows, omics data interpretation and biological reporting.",
    topics: ["RNA-seq", "Bioconductor", "Gene Expression", "Omics"],
  },
  {
    title: "Data Science & Machine Learning",
    level: "Applied analytics",
    description:
      "Data preparation, visualisation, supervised learning, model evaluation, prediction modelling and interpretation.",
    topics: ["Machine Learning", "Visualisation", "Prediction", "Evaluation"],
  },
  {
    title: "Dissertation & Research Project Support",
    level: "Academic project guidance",
    description:
      "Support for research questions, analysis planning, methodology, results interpretation, tables, figures and academic reporting.",
    topics: ["Dissertation", "Methods", "Results", "Reporting"],
  },
];
---

<section id="courses" class="px-6 py-24 md:px-10 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">
          Courses and guided learning
        </p>

        <h2 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">
          Organised learning pathways for quantitative subjects.
        </h2>

        <p class="mt-5 text-lg leading-8 text-slate-300">
          Courses will be organised around clear explanations, worked examples,
          software demonstrations, exercises and practical academic applications.
        </p>

        <a
          href="#contact"
          class="mt-8 inline-flex rounded-full bg-cyan-300 px-7 py-4 font-semibold text-slate-950 transition hover:bg-cyan-200"
        >
          Ask about course access
        </a>
      </div>

      <div class="grid gap-4">
        {courses.map((course, index) => (
          <article class="rounded-[2rem] border border-white/10 bg-white/[0.05] p-6 transition hover:border-cyan-300/30">
            <p class="text-sm text-cyan-300">
              0{index + 1} · {course.level}
            </p>

            <h3 class="mt-2 text-2xl font-semibold">{course.title}</h3>

            <p class="mt-3 text-sm leading-6 text-slate-400">
              {course.description}
            </p>

            <div class="mt-5 flex flex-wrap gap-2">
              {course.topics.map((topic) => (
                <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-slate-300">
                  {topic}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>