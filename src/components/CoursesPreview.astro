---
const courses = [
  {
    title: "Core Statistics",
    description: "Probability, inference, regression and applied analysis.",
  },
  {
    title: "Biostatistics",
    description: "Medical statistics, epidemiology and survival analysis.",
  },
  {
    title: "Programming",
    description: "R, Python, SPSS, SAS and Stata for academic analysis.",
  },
];
---

<section class="bg-[#f8f6f2] px-6 py-20 md:px-10 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-[#8C1515]">
      Courses
    </p>

    <h2 class="mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">
      Organised learning pathways.
    </h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {courses.map((course) => (
        <article class="border border-neutral-200 bg-white p-6 shadow-sm">
          <h3 class="text-2xl font-semibold tracking-tight text-neutral-950">
            {course.title}
          </h3>

          <p class="mt-3 text-sm leading-6 text-neutral-600">
            {course.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>